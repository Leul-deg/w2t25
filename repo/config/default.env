# Meridian — local development environment
# Copy to backend/.env and fill in real values before starting.

# PostgreSQL connection string
DATABASE_URL=postgres://meridian:meridian@localhost:5432/meridian

# Server bind address
HOST=127.0.0.1
PORT=8080

# Session secret — must be at least 64 characters.
# Generate a strong value with: openssl rand -hex 64
SESSION_SECRET=change_me_this_must_be_at_least_64_characters_long_in_production_replace_now

# Session lifetime in seconds (default 3600 = 1 hour)
SESSION_MAX_AGE_SECONDS=3600

# Log level: error | warn | info | debug | trace
LOG_LEVEL=info

# ── Backup settings ────────────────────────────────────────────────────────────
# AES-256-GCM encryption key for database backups.
# Leave empty to disable the backup API entirely.
# Generate a strong value with: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=

# Directory where encrypted backup files are stored (relative to backend/).
BACKUPS_DIR=../backups

# Directory where generated CSV report files are written (relative to backend/).
EXPORTS_DIR=../exports
